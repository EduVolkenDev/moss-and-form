---
import BaseLayout from '../layouts/BaseLayout.astro';

const collections = [
  {
    title: 'Botanical Panels',
    description:
      'Statement artificial compositions with layered depth, refined texture and a convincingly natural finish for elevated interiors.',
    tag: 'Installations',
    items: 18,
    image: '/images/gallery-triptych.png'
  },
  {
    title: 'Framed Garden Pieces',
    description:
      'Curated compositions blending flowers, foliage and decorative details in a contemporary artistic language.',
    tag: 'Wall Art',
    items: 12,
    image: '/images/gallery-triptych.png'
  },
  {
    title: 'Nature in Glass',
    description:
      'Small aquascapes and terrarium worlds made of moss, stone and delicate living-looking scenery.',
    tag: 'Terrariums & Aquascapes',
    items: 9,
    image: '/images/terrarium-pair.png'
  }
];

const highlights = [
  {
    title: 'Organic aesthetic',
    text: 'A calm premium visual identity shaped around texture, depth and natural composition.'
  },
  {
    title: 'Curated presentation',
    text: 'Each piece can be positioned as a singular artwork, a seasonal collection or a bespoke installation.'
  },
  {
    title: 'Simple management',
    text: 'The layout already leaves room for future inventory, pricing, availability and enquiry management.'
  }
];

const artworks = [
  {
    name: 'Suspended Grove',
    type: 'Floral panel',
    status: 'Available',
    size: '120 × 80 cm',
    price: 'On request'
  },
  {
    name: 'Silent Garden',
    type: 'Botanical panel',
    status: 'Commissioned',
    size: '160 × 100 cm',
    price: 'On request'
  },
  {
    name: 'Glass Microforest',
    type: 'Natural aquascape',
    status: 'Available',
    size: '45 × 30 cm',
    price: 'On request'
  },
  {
    name: 'Stone, Moss & Light',
    type: 'Art terrarium',
    status: 'In production',
    size: '60 × 40 cm',
    price: 'On request'
  }
];

const gallery = [
  {
    title: 'Botanical Texture',
    category: 'Foliage & florals',
    heightClass: 'card-tall',
    image: '/images/gallery-triptych.png'
  },
  {
    title: 'Natural Depth',
    category: 'Moss, stone & relief',
    heightClass: 'card-xl',
    image: '/images/terrarium-pair.png'
  },
  {
    title: 'Sculptural Piece',
    category: 'Authorial installation',
    heightClass: 'card-medium',
    image: '/images/gallery-triptych.png'
  },
  {
    title: 'Glass Ecosystem',
    category: 'Nature aquascape',
    heightClass: 'card-large',
    image: '/images/terrarium-pair.png'
  },
  {
    title: 'Living Details',
    category: 'Mini fauna & flora',
    heightClass: 'card-compact',
    image: '/images/gallery-triptych.png'
  },
  {
    title: 'Editorial Composition',
    category: 'Premium collection',
    heightClass: 'card-xxl',
    image: '/images/terrarium-pair.png'
  }
];
---

<BaseLayout
  title="Moss & Form — Botanical Art Studio"
  description="A clean artistic Astro landing page for botanical panels, terrariums and aquascapes."
>
  <div class="page-shell">
    <div class="ambient ambient-one"></div>
    <div class="ambient ambient-two"></div>
    <div class="ambient ambient-three"></div>

    <header class="site-header">
      <div class="container header-inner">
        <div>
          <p class="eyebrow">Studio Botanical Art</p>
          <div class="brand-name">Moss & Form</div>
        </div>

        <nav class="nav desktop-nav">
          <a href="#collections" data-i18n="nav.collections">Collections</a>
          <a href="#gallery" data-i18n="nav.gallery">Gallery</a>
          <a href="#management" data-i18n="nav.management">Management</a>
          <button class="lang-toggle" id="langToggle" type="button">PT</button>
          <a href="#contact" class="button button-secondary button-small" data-i18n="nav.contact">Get in touch</a>
        </nav>
      </div>
    </header>

    <main>
      <section class="hero container">
        <div class="hero-copy">
          <div class="pill" data-i18n="hero.pill">Portfolio • Exhibition • Management</div>
          <h1 data-i18n="hero.title">
            An artistic digital space for botanical works with presence, delicacy and premium value.
          </h1>
          <p class="hero-text" data-i18n="hero.text">
            Designed to showcase lifelike artificial panels, floral compositions, terrarium worlds,
            aquascapes and nature-led pieces that sit between art, landscape styling and interior design.
          </p>

          <div class="hero-actions">
            <a href="#gallery" class="button button-primary" data-i18n="hero.btn_gallery">View gallery</a>
            <a href="#management" class="button button-secondary" data-i18n="hero.btn_mgmt">Open collection management</a>
          </div>

          <div class="highlights-grid">
            <article class="soft-card">
              <h3 data-i18n="hl.1_title">Organic aesthetic</h3>
              <p data-i18n="hl.1_text">A calm premium visual identity shaped around texture, depth and natural composition.</p>
            </article>
            <article class="soft-card">
              <h3 data-i18n="hl.2_title">Curated presentation</h3>
              <p data-i18n="hl.2_text">Each piece can be positioned as a singular artwork, a seasonal collection or a bespoke installation.</p>
            </article>
            <article class="soft-card">
              <h3 data-i18n="hl.3_title">Simple management</h3>
              <p data-i18n="hl.3_text">The layout already leaves room for future inventory, pricing, availability and enquiry management.</p>
            </article>
          </div>
        </div>

        <div class="hero-visual">
          <div class="floating-panel floating-panel-sm">
            <img src="/images/terrarium-pair.png" alt="Copper terrarium pieces" loading="eager" />
          </div>
          <div class="floating-panel floating-panel-md">
            <img src="/images/gallery-triptych.png" alt="Botanical panel collection" loading="eager" />
            <div class="floating-label">
              <span data-i18n="float.label">Authorial pieces</span>
              <strong data-i18n="float.title">Organic visual language</strong>
            </div>
          </div>
          <div class="floating-panel floating-panel-caption">
            <span class="caption-label" data-i18n="float.caption_label">Aesthetic direction</span>
            <strong data-i18n="float.caption_title">Clean, natural, contemporary and gallery-led.</strong>
            <p data-i18n="float.caption_text">
              The work is framed as collectible art with a foundation ready for a proper catalogue and enquiry flow.
            </p>
          </div>
        </div>
      </section>

      <section id="collections" class="section container">
        <div class="section-head section-head-split">
          <div>
            <p class="eyebrow" data-i18n="col.eyebrow">Collections</p>
            <h2 data-i18n="col.title">How the work can be presented</h2>
          </div>
          <p class="section-support" data-i18n="col.support">
            Structured to exhibit the studio’s main categories with calm sophistication and a clear sense of value.
          </p>
        </div>

        <div class="collection-grid">
          {collections.map((item) => (
            <article class="collection-card">
              <div class="collection-meta">
                <span class="tag">{item.tag}</span>
                <span class="count">{item.items} works</span>
              </div>
              <h3>{item.title}</h3>
              <p>{item.description}</p>
              <img src={item.image} alt={item.title} class="collection-image" loading="lazy" />
            </article>
          ))}
        </div>
      </section>

      <section id="gallery" class="section container">
        <div class="section-head">
          <p class="eyebrow" data-i18n="gal.eyebrow">Gallery</p>
          <h2 data-i18n="gal.title">An editorial visual rhythm</h2>
          <p data-i18n="gal.text">
            Large clean blocks with enough breathing room to let each piece stand on its own — far from the feel of a generic shopfront.
          </p>
        </div>

        <div class="gallery-grid">
          {gallery.map((item) => (
            <article class={`gallery-card ${item.heightClass}`}>
              <img src={item.image} alt={item.title} loading="lazy" />
              <div class="gallery-overlay">
                <span>{item.category}</span>
                <strong>{item.title}</strong>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section id="management" class="section container management-grid">
        <article class="management-copy dark-card">
          <p class="eyebrow eyebrow-light" data-i18n="mgmt.eyebrow">Studio management</p>
          <h2 data-i18n="mgmt.title">Your collection, inventory and commissions in one place.</h2>
          <p data-i18n="mgmt.text">
            Register pieces, track availability, manage dimensions and pricing, organise by collection or style — and keep everything updated for clients and galleries.
          </p>

          <div class="feature-list">
            <div data-i18n="mgmt.f1">Register and edit artworks</div>
            <div data-i18n="mgmt.f2">Track availability and commissions</div>
            <div data-i18n="mgmt.f3">Organise by collection, style or setting</div>
            <div data-i18n="mgmt.f4">Manage pricing and dimensions</div>
          </div>

          <a href="/admin/" class="button button-primary" style="margin-top:1.5rem;width:fit-content;" data-i18n="mgmt.btn">Open studio panel</a>
        </article>

        <article class="dashboard-card" id="dashboardPreview">
          <div class="dashboard-top">
            <div>
              <p class="eyebrow" data-i18n="dash.eyebrow">Dashboard</p>
              <h3 data-i18n="dash.title">Registered works</h3>
            </div>
            <div class="dashboard-actions">
              <button class="button button-primary button-small" type="button">+ New artwork</button>
              <button class="button button-secondary button-small" type="button">Filter</button>
            </div>
          </div>

          <div class="dashboard-login-gate" id="adminGate">
            <div class="gate-icon">&#127793;</div>
            <strong data-i18n="gate.title">Studio access</strong>
            <p data-i18n="gate.text">Sign in to manage your collection, update availability and track commissions.</p>
            <div class="gate-form">
              <input type="email" id="adminEmail" placeholder="Your email" class="gate-input" />
              <input type="password" id="adminPass" placeholder="Password" class="gate-input" />
              <button class="button button-primary button-small" type="button" id="adminLoginBtn">Sign in</button>
            </div>
          </div>

          <div id="dashboardContent" style="display:none;">
            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th>Artwork</th>
                    <th>Type</th>
                    <th>Status</th>
                    <th>Size</th>
                    <th>Price</th>
                  </tr>
                </thead>
                <tbody>
                  {artworks.map((art) => (
                    <tr>
                      <td data-label="">{art.name}</td>
                      <td data-label="Type">{art.type}</td>
                      <td data-label="Status"><span class="status-pill">{art.status}</span></td>
                      <td data-label="Size">{art.size}</td>
                      <td data-label="Price">{art.price}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>

            <div class="stats-grid">
              <div class="stat-card">
                <strong>39</strong>
                <span data-i18n="stat.1">Works in archive</span>
              </div>
              <div class="stat-card">
                <strong>12</strong>
                <span data-i18n="stat.2">Available now</span>
              </div>
              <div class="stat-card">
                <strong>7</strong>
                <span data-i18n="stat.3">Commissioned</span>
              </div>
            </div>
          </div>
        </article>

        <script>
          // Simple admin gate — replace with real auth later
          const gate = document.getElementById('adminGate');
          const content = document.getElementById('dashboardContent');
          const loginBtn = document.getElementById('adminLoginBtn');
          const ADMIN_KEY = 'mossform_admin';

          if (localStorage.getItem(ADMIN_KEY)) {
            gate.style.display = 'none';
            content.style.display = '';
          }

          loginBtn?.addEventListener('click', () => {
            const email = document.getElementById('adminEmail')?.value;
            const pass = document.getElementById('adminPass')?.value;
            if (!email || !pass) return;
            // For now, any non-empty credentials unlock the dashboard
            // Replace with real auth when ready
            localStorage.setItem(ADMIN_KEY, '1');
            gate.style.display = 'none';
            content.style.display = '';
          });
        </script>
      </section>

      <section id="contact" class="section container">
        <div class="contact-card">
          <div>
            <p class="eyebrow" data-i18n="contact.eyebrow">Contact / commissions</p>
            <h2 data-i18n="contact.title">Interested in a piece? Let's talk.</h2>
            <p data-i18n="contact.text">
              Whether you're looking for a bespoke installation, a statement panel for your space, or a unique gift — reach out and we'll discuss what's possible.
            </p>
          </div>

          <form class="contact-form">
            <input type="text" placeholder="Your name" data-i18n-placeholder="contact.ph_name" />
            <input type="email" placeholder="Your email" data-i18n-placeholder="contact.ph_email" />
            <textarea placeholder="Describe the environment or piece you have in mind" data-i18n-placeholder="contact.ph_msg"></textarea>
            <button class="button button-primary" type="submit" data-i18n="contact.btn">Send enquiry</button>
          </form>
        </div>
      </section>
    </main>
  </div>

  <script is:inline>
  (function() {
    var PT = {
      "nav.collections": "Coleções",
      "nav.gallery": "Galeria",
      "nav.management": "Gestão",
      "nav.contact": "Fale conosco",
      "hero.pill": "Portfólio • Exposição • Gestão",
      "hero.title": "Um espaço digital artístico para obras botânicas com presença, delicadeza e valor premium.",
      "hero.text": "Criado para apresentar painéis artificiais realistas, composições florais, terrários, aquascapes e peças que transitam entre arte, paisagismo e design de interiores.",
      "hero.btn_gallery": "Ver galeria",
      "hero.btn_mgmt": "Gestão da coleção",
      "hl.1_title": "Estética orgânica",
      "hl.1_text": "Uma identidade visual premium e tranquila, moldada por textura, profundidade e composição natural.",
      "hl.2_title": "Apresentação curada",
      "hl.2_text": "Cada peça pode ser posicionada como obra singular, coleção sazonal ou instalação sob medida.",
      "hl.3_title": "Gestão prática",
      "hl.3_text": "O layout já prepara espaço para inventário, precificação, disponibilidade e fluxo de consultas.",
      "float.label": "Peças autorais",
      "float.title": "Linguagem visual orgânica",
      "float.caption_label": "Direção estética",
      "float.caption_title": "Limpa, natural, contemporânea e com referência de galeria.",
      "float.caption_text": "O trabalho é enquadrado como arte colecionável, com base pronta para catálogo e consultas.",
      "col.eyebrow": "Coleções",
      "col.title": "Como o trabalho pode ser apresentado",
      "col.support": "Estruturado para exibir as principais categorias do estúdio com sofisticação e senso claro de valor.",
      "gal.eyebrow": "Galeria",
      "gal.title": "Um ritmo visual editorial",
      "gal.text": "Blocos amplos e limpos com respiro suficiente para cada peça se destacar — longe de uma vitrine genérica.",
      "mgmt.eyebrow": "Gestão do estúdio",
      "mgmt.title": "Sua coleção, inventário e encomendas em um só lugar.",
      "mgmt.text": "Cadastre peças, acompanhe disponibilidade, gerencie dimensões e preços, organize por coleção ou estilo — e mantenha tudo atualizado para clientes e galerias.",
      "mgmt.f1": "Cadastrar e editar obras",
      "mgmt.f2": "Acompanhar disponibilidade e encomendas",
      "mgmt.f3": "Organizar por coleção, estilo ou ambiente",
      "mgmt.f4": "Gerenciar preços e dimensões",
      "mgmt.btn": "Abrir painel do estúdio",
      "dash.eyebrow": "Painel",
      "dash.title": "Obras cadastradas",
      "dash.btn_new": "+ Nova obra",
      "dash.btn_filter": "Filtrar",
      "gate.title": "Acesso ao estúdio",
      "gate.text": "Entre para gerenciar sua coleção, atualizar disponibilidade e acompanhar encomendas.",
      "gate.btn": "Entrar",
      "stat.1": "Obras no acervo",
      "stat.2": "Disponíveis agora",
      "stat.3": "Sob encomenda",
      "contact.eyebrow": "Contato / encomendas",
      "contact.title": "Interesse em alguma peça? Vamos conversar.",
      "contact.text": "Seja para uma instalação sob medida, um painel para seu espaço ou um presente único — entre em contato e conversamos sobre as possibilidades.",
      "contact.btn": "Enviar consulta",
      "contact.ph_name": "Seu nome",
      "contact.ph_email": "Seu email",
      "contact.ph_msg": "Descreva o ambiente ou peça que tem em mente"
    };

    var defaults = {};
    var lang = localStorage.getItem('mossform_lang') || 'en';

    function storeDefaults() {
      document.querySelectorAll('[data-i18n]').forEach(function(el) {
        var key = el.getAttribute('data-i18n');
        if (!defaults[key]) defaults[key] = el.textContent.trim();
      });
      document.querySelectorAll('[data-i18n-placeholder]').forEach(function(el) {
        var key = el.getAttribute('data-i18n-placeholder');
        if (!defaults[key]) defaults[key] = el.placeholder;
      });
    }

    function applyLang(l) {
      lang = l;
      localStorage.setItem('mossform_lang', l);
      var dict = l === 'pt' ? PT : defaults;
      document.querySelectorAll('[data-i18n]').forEach(function(el) {
        var key = el.getAttribute('data-i18n');
        if (dict[key]) el.textContent = dict[key];
      });
      document.querySelectorAll('[data-i18n-placeholder]').forEach(function(el) {
        var key = el.getAttribute('data-i18n-placeholder');
        if (dict[key]) el.placeholder = dict[key];
      });
      var btn = document.getElementById('langToggle');
      if (btn) btn.textContent = l === 'pt' ? 'EN' : 'PT';
    }

    storeDefaults();
    if (lang === 'pt') applyLang('pt');

    document.getElementById('langToggle')?.addEventListener('click', function() {
      applyLang(lang === 'pt' ? 'en' : 'pt');
    });
  })();
  </script>
</BaseLayout>
